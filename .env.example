# Core runtime settings
# Input and output paths are provided via CLI flags:
#   cargo run --release -- run --input /path/to/CID-InChI-Key.full.txt.zst --output-dir /path/to/run
CLASSYFIRE_BASE_URL=http://classyfire.wishartlab.com
CLASSYFIRE_USER_AGENT=classyfire-get-downloader/0.1
CLASSYFIRE_TIMEOUT_SECONDS=30
CLASSYFIRE_GET_SLEEP_SECONDS=5
CLASSYFIRE_THROTTLE_BACKOFF_SECONDS=300
CLASSYFIRE_STATUS_INTERVAL_SECONDS=1
